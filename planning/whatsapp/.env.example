# Evolution API — variáveis da Fase 0.
# Copie para `.env` (NÃO comite o .env real) e preencha os segredos.
#   cp .env.example .env
#
# Gere os segredos com:
#   openssl rand -hex 32

# URL pública HTTPS do Evolution (subdomínio que aponta pro servidor).
EVOLUTION_SERVER_URL=https://evo.nairavian-n8n.de

# Chave global da API do Evolution (header `apikey`). GERE uma forte.
EVOLUTION_API_KEY=__troque_por_openssl_rand_hex_32__

# Senha do Postgres dedicado do Evolution. GERE uma forte.
EVOLUTION_DB_PASSWORD=__troque_por_openssl_rand_hex_32__
