{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mara-sandra-connect",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "routes": [
    { "pattern": "marasandraconnect.com", "custom_domain": true },
    { "pattern": "www.marasandraconnect.com", "custom_domain": true }
  ]
}
